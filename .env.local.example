# Copy this file to .env.local and add ONE key. Never commit .env.local.
# The chat assistant uses whichever key is present (OpenAI is preferred if both set).

# OpenAI (recommended — cheap with gpt-4o-mini)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Or use Anthropic Claude instead
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
